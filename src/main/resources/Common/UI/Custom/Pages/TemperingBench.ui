$C = "../Common.ui";

$C.@PageOverlay {}

$C.@DecoratedContainer {
    @CloseButton = true;
    Anchor: (Width: 620, Height: 420);

    #Title {
        Group {
            $C.@Title #TitleText {
                @Text = "Tempering Bench";
            }
        }
    }

    #Content {
        LayoutMode: Left;

        // ═══════════════════════════════════════
        // LEFT PANEL: Temperable items list
        // ═══════════════════════════════════════
        Group #ItemListPanel {
            Anchor: (Width: 200);
            LayoutMode: Top;

            $C.@PanelTitle { @Text = "YOUR EQUIPMENT"; }

            Group #ItemListContainer {
                Padding: (Top: 4);
                FlexWeight: 1;
                LayoutMode: TopScrolling;
                ScrollbarStyle: $C.@DefaultScrollbarStyle;

                Group #ItemList {
                    LayoutMode: Top;
                }
            }
        }

        $C.@VerticalSeparator {}

        // ═══════════════════════════════════════
        // RIGHT PANEL: Tempering details
        // ═══════════════════════════════════════
        Group #DetailsPanel {
            Anchor: (Full: 0);
            LayoutMode: Top;
            Padding: (Left: 12, Right: 12, Top: 8);

            // Empty state message
            Label #EmptyState {
                Text: "Select an item to temper";
                Style: (FontSize: 14, TextColor: #8a9aaa, VerticalAlignment: Center, HorizontalAlignment: Center);
                Anchor: (Height: 30);
            }

            // Item preview section (hidden by default)
            Group #PreviewSection {
                Visible: false;
                LayoutMode: Top;

                // Item header: icon + name + rarity
                Group #ItemHeader {
                    LayoutMode: Left;
                    Anchor: (Height: 52);

                    Group #PreviewBorder {
                        Anchor: (Width: 48, Height: 48);
                        Background: #1a2530;
                        Padding: (Full: 2);

                        ItemSlot #PreviewSlot {
                            Anchor: (Full: 0);
                            ShowQualityBackground: true;
                        }
                    }

                    Group #ItemInfo {
                        FlexWeight: 1;
                        LayoutMode: Top;
                        Padding: (Left: 8);

                        Label #ItemName {
                            Text: "";
                            Style: (FontSize: 16, TextColor: #FFFFFF, RenderBold: true);
                            Anchor: (Height: 22);
                        }

                        Label #ItemSubtitle {
                            Text: "";
                            Style: (FontSize: 12, TextColor: #ccb588);
                            Anchor: (Height: 18);
                        }
                    }
                }

                // Stats section
                $C.@PanelSeparatorFancy { Padding: (Top: 6, Bottom: 6); }

                Group #StatsSection {
                    LayoutMode: Top;
                    Anchor: (Height: 80);

                    Label #StatsTitle {
                        Text: "Current Stats";
                        Style: (FontSize: 12, TextColor: #8a9aaa, RenderBold: true);
                        Anchor: (Height: 18);
                    }

                    Group #StatsList {
                        LayoutMode: Top;
                        Padding: (Top: 2);
                    }
                }

                // Cost section
                $C.@PanelSeparatorFancy { Padding: (Top: 4, Bottom: 4); }

                Group #CostSection {
                    LayoutMode: Left;
                    Anchor: (Height: 36);

                    Label #CostLabel {
                        Text: "Cost:";
                        Style: (FontSize: 13, TextColor: #8a9aaa, VerticalAlignment: Center, RenderBold: true);
                        Anchor: (Width: 40);
                    }

                    Group #CostItems {
                        FlexWeight: 1;
                        LayoutMode: Left;

                        ItemSlot #CostSlot {
                            Anchor: (Width: 32, Height: 32);
                        }

                        Label #CostText {
                            Text: "";
                            Style: (FontSize: 13, TextColor: #FFFFFF, VerticalAlignment: Center);
                            Padding: (Left: 4);
                        }
                    }
                }

                // Result info
                Group #ResultInfo {
                    Padding: (Top: 6);
                    Anchor: (Height: 22);

                    Label #ResultText {
                        Text: "Tempering rerolls rarity and affix.";
                        Style: (FontSize: 11, TextColor: #6a7a8a, HorizontalAlignment: Center);
                    }
                }

                // Temper button
                Group #TemperButtonRow {
                    LayoutMode: Right;
                    Padding: (Top: 8);
                    Anchor: (Height: 36);

                    $C.@TextButton #TemperButton {
                        Text: "TEMPER";
                        Anchor: (Width: 140, Height: 34);
                    }
                }
            }
        }
    }
}
